# Stack-chan STT + Dialog pipeline (Python) environment example
# Copy to ".env" and fill in values as needed.

# ---- Server bind ----
STT_HOST=0.0.0.0
STT_PORT=8088

# ---- VOSK ----
# If omitted, defaults to ./model (relative to server.py).
#VOSK_MODEL_PATH=./model
VOSK_SAMPLE_RATE=16000

# Optional: sounddevice input device index (integer). If omitted, default input is used.
#INPUT_DEVICE=0

# ---- OpenAI (required unless you run with --stt-only) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional: for compatible endpoints (e.g. local gateway)
#OPENAI_BASE_URL=

# Optional: override system prompt (Japanese recommended)
#OPENAI_SYSTEM=You are 「スタックちゃん(Stack-chan)」...

# ---- ACK / ready handling ----
# Max seconds to wait for {"type":"ready"} after each assistant chunk.
READY_TIMEOUT_SEC=120

# ---- Barge-in (user speaks while system is speaking) ----
# buffer: (default) speak to the end, then merge user utterances and generate next response
# continue: same as buffer for now (reserved for future)
# discard: ignore all user utterances while assistant is speaking (no buffer)
# regenerate: stop sending remaining chunks, then regenerate from new user utterance(s)
# pause_resume: stop sending remaining, handle user, then resume remaining chunks (experimental)
BARGE_IN_MODE=buffer

# ---- Utterance endpoint tuning (VOSK + simple VAD) ----
# If VOSK doesn't end an utterance, we force-finalize after this silence gap.
SILENCE_SEC=2.0
# RMS threshold to consider as "voice". Raise if it triggers too easily.
VAD_RMS=500

